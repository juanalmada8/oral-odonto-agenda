APP_NAME=ORAL
APP_ENV=production
DEBUG=false
API_PREFIX=/api/v1
APP_TIMEZONE=America/Argentina/Buenos_Aires
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

DATABASE_URL=postgresql+psycopg://oral_user:oral_password@postgres-host:5432/oral_db
TEST_DATABASE_URL=sqlite+pysqlite:///:memory:

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tu_cuenta@gmail.com
SMTP_PASSWORD=tu_app_password
SMTP_USE_TLS=true
EMAIL_FROM=tu_cuenta@gmail.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

REMINDER_HOURS_AHEAD=24
